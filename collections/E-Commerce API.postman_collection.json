    {
      "name": "Get Single Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Validate status code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Validate response time\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// Parse JSON response\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Validate required fields\r",
              "pm.test(\"Response contains id\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains title\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"title\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains price\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"price\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains category\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"category\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains description\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"description\");\r",
              "});\r",
              "\r",
              "// Validate data types\r",
              "pm.test(\"Product id is a number\", function () {\r",
              "    pm.expect(jsonData.id).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.test(\"Product title is a string\", function () {\r",
              "    pm.expect(jsonData.title).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Product price is a number\", function () {\r",
              "    pm.expect(jsonData.price).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Validate product ID\r",
              "pm.test(\"Product ID equals 1\", function () {\r",
              "    pm.expect(jsonData.id).to.eql(1);\r",
              "});\r",
              "\r",
              "// Validate price is positive\r",
              "pm.test(\"Price is greater than zero\", function () {\r",
              "    pm.expect(jsonData.price).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
